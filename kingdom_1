#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <stdbool.h> 
#include "errorCheck.h"
#include <unistd.h>

int kingdom1(){
  int choice, rc;
  printf("Welcome to Tiffany's Kingdom!\nGold Coins: %d\n\n", currency);
  FILE* art = fopen("art.txt","r");
  for(i = 0; i < 22; i++){
    fgets(printLine, 200, art);
    printf("%s", printLine);
  }
  printf("\n\n");
  fclose(art);
  sleep(2);
  printf("Where would you like to go?\nThe Dungeon (1)\nThe Throne Room (2)\nExplore a Different Land (3)\nContinue on your Travels/Leave (0)\n");
  rc = scanf("%d", &choice);
  choice = errorCheck(rc, choice, 3);
  if (choice == 1){
    int dungeon_choice, check_brick;
    printf("You head down a dark staircase toward the dungeon...\nAs you make your way down you trace your hand along the wall, one of the bricks feels loose...\n");
    sleep(2);
    printf("Inspect the brick (1)\nIgnore it and continue to the dungeon (2)\n");
    rc = scanf("%d", &check_brick);
    check_brick = errorCheck(rc, check_brick, 2);
    if (check_brick == 1){
      printf("You shuffle the brick and it falls out of the wall. A small pouch sits in the gap behind it.\n You pick it up...\n");
      sleep(1);
      printf("You open the pouch and find 30 gold coins!\nYou replace the brick excitedly and continue down to the dungeon.\n");
      currency += 30;
    }   
    sleep(2);
    printf("You reach the bottom of the straicase and enter the dungeon.\n\n");
    FILE* art = fopen("art.txt","r");
    for(i=0; i<=105; i++){
      fgets(printLine, 200, art);
    }
    for(i=105; i<127; i++){
      fgets(printLine, 200, art);
      printf("%s", printLine);
    }
    printf("\n\n");
    fclose(art);
    sleep(2);
    printf("The dungeon master stands menacingly beside the entrance...\n");
    sleep(2);
    printf("Would you like to: \nSpeak to the Dungeon Master (1)\nReturn to the kingdom center (0)\n");
    rc = scanf("%d", &dungeon_choice);
    dungeon_choice = errorCheck(rc, dungeon_choice, 1);
    if (dungeon_choice == 0){
      printf("You chose to return to the kingdom center.\n\n");
      return 2;
    }
    else if (dungeon_choice == 1){
      int sneak, prisoner_choice;
      printf("You approach Ariela, the Dungeon Master.\n");
      printf("You ask how long she has worked there.\n");
      sleep(1);
      printf("\033[34mI lose track of time down here... it's always so dark.\n");
      sleep(1);
      printf("\033[0mHuh. Is there many prisoners at the moment?\n");
      sleep(1);
      printf("\033[34mOnly 1, the lands have been peaceful as of late.\n");
      sleep(1);
      printf("\033[0mCan I speak to the prisoner?\n");
      sleep(1);
      printf("\033[34mAbsolutely not!\n\033[0mShe slams her guard pole on the ground.\n\033[34mYou best be leaving now...\n");
      sleep(1);
      printf("\033[0mYou are taken aback by the guard's abrupt response, but you are curious about the prisoner.\n");
      sleep(2);
      printf("Leave the dungeon (1)\nTry and sneak past (2)\n");
      rc = scanf("%d", &prisoner_choice);
      prisoner_choice = errorCheck(rc, prisoner_choice, 2);
      if (prisoner_choice == 1){
        return 2;
      }
      else if (prisoner_choice == 2){
        sneak = rand() % 2;
        if (sneak == 0){
          printf("Uh oh, you got caught. Ariela escorts you back to the kingdom center...\n\n");
          return 2;
        }
        else if (sneak == 1){
          printf("You manage to sneak past the guard and walk over to one of the cells where a prisoner sits...\n");
          printf("The prisoner looks up at you. You ask what his name is.\n");
          sleep(1);
          printf("\033[34mLuca, not that it's any of your business.\n");
          sleep(1);
          printf("\033[0mRude... you think to yourself.\nWhy are you here?\n");
          sleep(1);
          printf("\033[34mI stole 5 beers from the local tavern, not that it's any of your business.\n");
          sleep(1);
          printf("\033[0mHuh, he sure does talk a lot for someone who thinks it's no one's business...\n");
          sleep(1);
          printf("You sneak back past the guard and leave the dungeon.\n\n");
          return 2;
        }
      }
    }
  }
  else if (choice == 2){
    int throne_choice;
    printf("You enter the throne room. Large windows line the walls, opening up to the picturesque landscape.\n");
    printf("Her Majesty sits royally upon her throne, the court jester is close beside her.\n\n"); 
    FILE* art = fopen("art.txt", "r");
    for(i = 0; i < 129; i++){
      fgets(printLine, 200, art);
    }
    for(i = 129; i < 186; i++){
      fgets(printLine, 200, art);
      printf("%s", printLine);
    }
    printf("\n\n");
    fclose(art);
    sleep(2);
    printf("Would you like to: \nSpeak to the court jester (1)\nApproach her Majesty Tiffany Terry (2)\nReturn to the kingdom center (0)\n");
    rc = scanf("%d", &throne_choice);
    throne_choice = errorCheck(rc, throne_choice, 2);
    if (throne_choice == 0){
      printf("You chose to return to the kingdom centre.\n\n");
      return 2;
    }
    else if (throne_choice == 1){
      printf("You walk over to Austin, the court jester.\nYou notice his unusually long shoes...\n");
      printf("\033[34mWelcome! Welcome! Care to see a magic trick?\n");
      sleep(1);
      printf("\033[0mHe begins the trick before you can respond...\n");
      sleep(1);
      printf("He holds out a hand of cards.\n\033[34mPick a card! Any card!\n");
      sleep(1);
      printf("\033[0mYou take one from the pile.\n");
      sleep(1);
      printf("\033[34mNow I shall guess your card!\nMy senses are telling me you picked a 9 of hearts!\n");
      sleep(1);
      printf("\033[0mYou look down at your card. It's a queen of spades...\n");
      sleep(1);
      printf("You show the jester, and he looks at his cards confused.\nHe apologises before walking away quickly...\nYou return to the kingdom center.\n\n");
      return 2;
    }
    else if (throne_choice == 2){
      printf("You approach her Majesty at her throne and bow.\n");
      sleep(1);
      printf("\033[34mWelcome to my kingdom! I hope you have been enjoying your time here.\n");
      sleep(1);
      printf("\033[0mThank you! My travels in these lands have gone well so far.\n");
      sleep(1);
      printf("\033[34mI'm glad to hear that!\033[0m\n\n");
      if (visited_gala == false){
        printf("\033[34mThere is a gala that has been going on in Nick's Kingdom. We host the grandest parties in the land, I'm about to go there myself. You should definitely check it out!\033[0m\n\n");
      }      
      return 2;
    }
  }
  else if (choice == 3){
    int explore_choice;
    printf("You chose to explore a different Land.\nWhere would you like to go?\n");
    sleep(2);
    printf("The Common Land (1)\nNick's Kingdom 2 (2)\nThe Rafferty Kingdom (3)\nThe Woods (4)\n");
    rc = scanf("%d", &explore_choice);
    explore_choice = errorCheck(rc, explore_choice, 4);
    if (explore_choice == 1){
      return 1;
    }
    if (explore_choice == 2){
      return 3;
    }
    if (explore_choice == 3){
      return 4;
    }
    if (explore_choice == 4){
      return 5;
    }
  }
  else if(choice == 0){
    return 0;
  }
  return 0;
}
