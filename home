#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <stdbool.h> 
#include "errorCheck.h"
#include <unistd.h>

int home(){
  int choice, rc;
  printf("Welcome to the Common Place!\nGold Coins: %d\n", *x);
  sleep(2);
  printf("Where would you like to go?\nDillon's Bakery (1)\nSophie's Tavern (2)\nCarlos's Blacksmith (3)\nExplore a Different Land (4)\nContinue on your Travels/Leave (0)\n");
  rc = scanf("%d", &choice);
  choice = errorCheck(rc, choice, 4);
  if (choice == 1){
    int bakery_choice;
    printf("You chose to go to Dillon's Bakery.\nIt smells delicious!\n"); 
    sleep(2);
    printf("Would you like to: \nBuy some bread (1)\nTalk to the Bakery Helper (2)\nReturn to the Common Place (0)\n");
    rc = scanf("%d", &bakery_choice);
    bakery_choice = errorCheck(rc, bakery_choice, 4);
    if (bakery_choice == 0){
      printf("You chose to return to the Common Place.");
      return 1;
    }
    else if (bakery_choice == 1){
      int buy_bread;
      printf("You chose to buy some bread. Bread costs 15 ____.\nConfirm your purchase (1)\nReturn back to the Common Place (0)\n");
      rc = scanf("%d", &buy_bread);
      buy_bread = errorCheck(rc, buy_bread, 1);
      if (buy_bread == 1){
        printf("That Bread was delicious!\nLet's head back to the Common Place and explore some more.\n");
        *x-=15;
        return 1;
      }
      else if (buy_bread == 0){
        printf("Alright, your missing out!\nLet's head back to the Common Place and explore some more.\n");
        return 1;
      }
    }
    else if (bakery_choice == 2){
      printf("You chose to talk to the Bakery Helper.\n______________________dialogue_________________________\nLet's head back to the Common Place and explore some more.\n");
      return 1;
    }
  }
  else if (choice == 2){
    int bounced, tavern_choice;
    printf("You chose to go to Sophie's Tavern.\n On the way in, the bouncer Ben walks up to you.\n");
    bounced = rand()%3;
    if (bounced == 1){
      printf("Uh Oh, you got bounced by Ben the bouncer.\nBack to the Common Place it is.\n");
      return 1;
    }
    printf("You got lucky this time. The bouncer Ben lets you inside.\n");
    printf("The place is crowded.\n");
    sleep(2);
    printf("Would you like to: \nBuy a drink (1)\nTalk to _____ (2)\nReturn to the Common Place (0)");
    rc = scanf("%d", &tavern_choice);
    tavern_choice = errorCheck(rc, tavern_choice, 2);
    if (tavern_choice == 0){
      printf("You chose to return to the Common Place.");
      return 1;
    }
    else if (tavern_choice == 1){
      int buy_beer;
      printf("You chose to buy a drink. Beer costs 30 ____.\nConfirm your purchase (1)\nReturn back to the Common Place (0)");
      rc = scanf("%d", &buy_beer);
      buy_beer = errorCheck(rc, buy_beer, 1);
      if (buy_beer == 1){
        printf("That beer was delicious!\nLet's head back to the Common Place and explore some more.\n");
        *x-=30;
        return 1;
      }
      else if (buy_beer == 0){
        printf("Alright, your missing out!\nLet's head back to the Common Place and explore some more.\n");
        return 1;
      }
    }
    else if (tavern_choice == 2){
      printf("You chose to talk to _______.\n______dialogue______\nLet's head back to the Common Place and explore some more.\n");
      return 1;
    }
  }
  else if (choice == 3){
    int buy_blacksmith, weapon_choice, buy_weapon;
    printf("You chose to go to Carlos's Blacksmith.\n");
    sleep(2);
    printf("Would you like to: \nPurchase a weapon (1)\nReturn back to the Common Place (0)");
    rc = scanf("%d", &buy_blacksmith);
    buy_blacksmith = errorCheck(rc, buy_blacksmith, 1);
    if (buy_blacksmith == 1){
      printf("You chose to buy a weapon. Carlos greets you and provides you with 3 weapon options. Would you like to: \nBuy a Sword (1)\nBuy a Battle Axe (2)\nBuy a Spiked Club (3)\nReturn to the Common Place (0)\n");
      rc = scanf("%d", &weapon_choice);
      weapon_choice = errorCheck(rc, weapon_choice, 3);
      if (weapon_choice == 0){
        printf("Alright, your missing out!\nLet's head back to the Common Place and explore some more.\n");
        return 1;
      }
      else if (weapon_choice == 1){
        printf("You chose to buy a Sword! Great Choice! A Sword costs 55 Gold Coins\n");
      }
      else if (weapon_choice == 2){
        printf("You chose to buy a Battle Axe! Scary! A Battle Axe costs 50 Gold Coins\n");
      }
      else if (weapon_choice == 3){
        printf("You chose to buy a Spiked Club! Nice! A Spiked Club costs 45 Gold Coins\n");
      }
      printf("Confirm your purchase (1)\nReturn back to the Common Place (0)");
      rc = scanf("%d", &buy_weapon);
      buy_weapon = errorCheck(rc, buy_weapon, 1);
      if (buy_weapon == 1){
        printf("Thank you Carlos. Now you are prepared for Battle!\nLet's head back to the Common Place and explore some more.\n");
        if (weapon_choice == 1){
          *x-=55;
        }
        else if (weapon_choice == 2){
          *x-=50;
        }
        else if (weapon_choice == 3){
          *x-=45;
        }
        return 1;
      }
      else if (buy_weapon == 0){
        printf("Alright, your missing out!\nLet's head back to the Common Place and explore some more.\n");
        return 1;
      }
    }
    else if (buy_blacksmith == 0){
      printf("Alright, your missing out!\nLet's head back to the Common Place and explore some more.\n");
      return 1;
    }
  }
  else if (choice == 4){
    int explore_choice;
    printf("You chose to explore a different Land.\nWhere would you like to go?\n");
    sleep(2);
    printf("Tiffany's Kingdom (1)\nNick's Kingdom (2)\nThe Rafferty Kingdom (3)\nThe Woods (4)\n");
    rc = scanf("%d", &explore_choice);
    choice = errorCheck(rc, choice, 4);
    if (explore_choice == 1){
      return 2;
    }
    if (explore_choice == 2){
      return 3;
    }
    if (explore_choice == 3){
      return 4;
    }
    if (explore_choice==4){
      return 5;
    }
  }
  else if(choice==0){
    return 0;
  }
}
