#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <stdbool.h> 
#include "errorCheck.h"
#include <unistd.h>

int kingdom2(){
  int choice, rc;
  printf("Welcome to Nick's Kingdom!\nGold Coins: %d\n\n", currency);
  FILE* art = fopen("art.txt","r");
  for(i = 0; i <= 22; i++){
    fgets(printLine, 200, art);
  }
  for(i = 22; i <= 40; i++){
    fgets(printLine, 200, art);
    printf("%s", printLine);
  }
  printf("\n\n");
  fclose(art);
  sleep(2);
  printf("What would you like to do?\nEnter the castle (1)\nExplore a Different Land (2)\nContinue on your Travels/Leave (0)\n");
  rc = scanf("%d", &choice);
  choice = errorCheck(rc, choice, 2);
  if (choice == 1){
    int gala_choice;
    printf("You approach the castle and hear lots of noise and music...\n");
    sleep(1);
    printf("A grand gala is being hosted! You excitedly enter the castle and follow a crowd of people into the royal ball room!\n");
    FILE* art = fopen("art.txt","r");
    for(i = 0; i <= 192; i++){
      fgets(printLine, 200, art);
    }
    for(i = 192; i <= 215; i++){
      fgets(printLine, 200, art);
      printf("%s", printLine);
    }
    printf("\n\n");
    fclose(art);
    visited_gala = true;
    sleep(2);
    printf("Would you like to: \nAsk Cam the entertainer to play a song (1)\nSpeak to the King (2)\nReturn to the kingdom center (0)\n");
    rc = scanf("%d", &gala_choice);
    gala_choice = errorCheck(rc, gala_choice, 2);
    if (gala_choice == 0){
      printf("You chose to return to the kingdom centre.\n\n");
      return 3;
    }
    else if (gala_choice == 1){
      int song;
      printf("You walk over to Cam, the most renowned musical performer in the lands.\n");
      sleep(1);
      printf("You request your favourite song to be played.\n");
      sleep(1);
      printf("\033[34mOf course! It is 40 gold coins to make a song request.\n");
      sleep(2);
      printf("\033[0mConfirm song request (1)\nMaybe next time... (2)\n");
      rc = scanf("%d", &song);
      song = errorCheck(rc, song, 2);
      if (song == 1){
        printf("Cam begins to play your song. You smile and join the crowd of people on the dance floor until the song is over!\n\n");
        currency -= 40;
      }
      else if (song == 2){
        printf("40 gold coins is a lot... You change your mind and head back to the kingdom center.\n\n");
      }
      return 3;
    }
    else if (gala_choice == 2){
      int game_choice, card1, card2, guess;
      printf("You see the King at a card table across the room.\n");
      sleep(1);
      printf("You approach politely and introduce yourself.\n");
      sleep(2);
      printf("\033[34mHow nice to meet you! Welcome to my kingdom, you have come to visit at a terrific time!\n");
      sleep(1);
      printf("Would you like to play a round of this game with me? You must bet 10 gold coins to play.\n");
      sleep(2);
      printf("\033[0mAccept the offer (1)\nPolitely decline (2)\n");
      rc = scanf("%d", &game_choice);
      game_choice = errorCheck(rc, game_choice, 2);
      if (game_choice == 1){
        printf("\033[34mTerrific! I will draw a card between 1 and 10. You will guess whether the next card will be higher or lower than my card.\n");
        sleep(1);
        printf("If you are correct, you get your gold coins back plus my ten that I bet! If you lose, I keep the winnings.\n");
        sleep(1);
        card1 = rand() % 10 + 1;
        printf("\033[0mThe King draws the first card...\n");
        sleep(1);
        printf("It's a %d! Now make your guess:\nHigher (1)\nLower(2)\n", card1);
        rc = scanf("%d", &guess);
        guess = errorCheck(rc, guess, 2);
        card2 = rand() % 10 + 1;
        printf("You draw the second card, it's a %d...\n", card2);
        if (guess == 1){
          if (card2 > card1){
            printf("\033[34mCongratulations! You won!\033[0m\n\n");
            currency += 10;
          }
          else if (card2 < card1){
            printf("\033[34mUh oh... Better luck next time!\033[0m\n\n");
            currency -= 10;
          }
          else if (card1 == card2){
            printf("\033[34mIt's a tie! Looks like we both get to keep our coins this time!\033[0m\n\n");
          }
        }
        else if (guess == 2){
          if (card1 > card2){
            printf("\033[34mCongratulations! You won!\033[0m\n\n");
            currency += 10;
          }
          else if (card1 < card2){
            printf("\033[34mUh oh... Better luck next time!\033[0m\n\n");
            currency -= 10;
          }
          else if (card1 == card2){
            printf("\033[34mIt's a tie! Looks like we both get to keep our coins this time!\033[0m\n\n");
          }
        }
      }
      else if (game_choice == 2){
        printf("\033[34mThat's too bad... Maybe next time!\n");
        sleep(1);
        printf("It was nice speaking to you!\033[0m\n\n");
      }
      return 3;
    }
  }
  else if (choice == 2){
    int explore_choice;
    printf("You chose to explore a different Land.\nWhere would you like to go?\n");
    sleep(2);
    printf("The Common Land (1)\nTiffany's Kingdom 2 (2)\nThe Rafferty Kingdom (3)\nThe Woods (4)\n");
    rc = scanf("%d", &explore_choice);
    explore_choice = errorCheck(rc, explore_choice, 4);
    if (explore_choice == 1){
      return 1;
    }
    if (explore_choice == 2){
      return 2;
    }
    if (explore_choice == 3){
      return 4;
    }
    if (explore_choice == 4){
      return 5;
    }
  }
  else if(choice == 0){
    return 0;
  }
}
